{
    "name": "christianjbrown/php-oauth2-client-lib",
    "require": {
        "php": "^8.3",
        "christianjbrown/php-api-client-lib": "dev-main",
        "christianjbrown/php-key-value-store-lib": "dev-main",
        "psr/http-client": "^1.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^12.0",
        "christianjbrown/php-code-quality-scripts": "dev-main"
    },
    "autoload": {
        "psr-4": {
            "ChristianBrown\\OAuth2Client\\": "src/",
            "ChristianBrown\\OAuth2Client\\Tests\\": "tests/"
        }
    },
    "repositories": [
        {"type": "github", "url": "git@github.com:christianjbrown/php-api-client-lib.git"},
        {"type": "github", "url": "git@github.com:christianjbrown/php-code-quality-scripts.git"},
        {"type": "github", "url": "git@github.com:christianjbrown/php-key-value-store-lib.git"}
    ],
    "config": {
        "bin-dir": "bin"
    },
    "scripts": {
        "check-style": ["clear && ./bin/php-cs ./src ./tests"],
        "fix-style": ["clear && ./bin/php-cs-fix ./src ./tests"],
        "test": ["clear && XDEBUG_MODE=coverage ./bin/phpunit -d memory_limit=512M && open ./.phpunit.cache/code-coverage-html/index.html"]
    }
}
